# Supabase Configuration (REQUIRED)
# Replace these with your Supabase Cloud project values for production
# Or use local values (http://127.0.0.1:54321) for local development
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_AUTH_GOOGLE_ENABLED="true"

# Stripe Configuration (OPTIONAL - Payments will fail without this)
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Optional: Service Role Key (Server-only, never expose on client)
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
